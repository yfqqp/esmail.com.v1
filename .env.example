# ─── Database (Postgres — can be hosted on Supabase or any provider) ─────────
# Required. A standard Postgres connection string. If hosting on Supabase,
# use the "Connection string" from Project Settings → Database (the pooled
# connection string is recommended for serverless/Vercel deployments).
# This project does NOT use Supabase Auth — only Postgres itself.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Session signing ───────────────────────────────────────────────────────
# Required. Used to sign the HttpOnly session JWT. Must be at least 32
# characters, cryptographically random. Generate one with:
#   openssl rand -base64 32
SESSION_SECRET=

# ─── OTP delivery: Telegram (optional, but at least one of Telegram/Email is required) ─
# Create a bot via @BotFather on Telegram to get a token. TELEGRAM_OWNER_CHAT_ID
# is your personal numeric chat ID (message @userinfobot to find it).
# NEVER commit real values here — set them only in your hosting provider's
# environment variable settings.
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# ─── OTP delivery: Email via Resend (optional, but at least one of Telegram/Email is required) ─
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# ─── Cloudinary ──────────────────────────────────────────────────────────────
# Required for media uploads (admin Media Library, hero/project images, etc.)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── AI (chat + embeddings) ───────────────────────────────────────────────────
# Optional at launch. Used for both chat completion and embeddings
# (gpt-4o-mini + text-embedding-3-small). The AI Assistant block degrades
# gracefully to a "setup required" state in the UI if this is unset.
OPENAI_API_KEY=sk-...

# ─── App ─────────────────────────────────────────────────────────────────────
# Required. Feeds the sitemap, robots.txt, and Open Graph URLs — must match
# your real production domain once deployed.
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ─── Scheduled jobs (optional) ────────────────────────────────────────────────
# Only required if you want the hourly analytics refresh to run via a
# Vercel Cron Job instead of calling it manually from /admin/analytics.
# Generate any long random string.
CRON_SECRET=
